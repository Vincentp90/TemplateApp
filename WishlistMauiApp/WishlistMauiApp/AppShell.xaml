<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="WishlistMauiApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:WishlistMauiApp"
    xmlns:pages="clr-namespace:WishlistMauiApp.Pages"
    Title="WishlistMauiApp">

    <ShellContent Route="login" ContentTemplate="{DataTemplate pages:LoginPage}" />
    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
