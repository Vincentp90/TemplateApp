{
  "name": "My App",
  "dockerComposeFile": "../docker-compose.devcontainer.yml",
  "service": "devc",
  "workspaceFolder": "/workspace",
  //"runServices": ["devc"],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-dev-containers",
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "humao.rest-client"
      ]
    }
  },
  "remoteEnv": {
    "TESTCONTAINERS_HOST_OVERRIDE": "host.docker.internal",
    "NODE_ENV": "devcontainer",
    "ASPNETCORE_ENVIRONMENT": "Devcontainer",
    "DOTNET_USE_POLLING_FILE_WATCHER": "false"
  },
  "features": { 
    "ghcr.io/devcontainers/features/node:2.0.0": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1.10.0": {}
  },
  "postCreateCommand": "mkdir -p ~/.pi/agent && ln -sf ${containerWorkspaceFolder}/.pi/agent/models.json ~/.pi/agent/models.json && ln -sf ${containerWorkspaceFolder}/.pi/agent/auth.json ~/.pi/agent/auth.json && npm install -g @earendil-works/pi-coding-agent"
}