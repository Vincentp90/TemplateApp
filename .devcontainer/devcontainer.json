{
  "name": "My App",
  "dockerComposeFile": "../docker-compose.devcontainer.yml",
  "service": "api",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": ["ms-vscode.vscode-dev-containers", "ms-dotnettools.csharp"]
    }
  },
  "remoteEnv": {
    "TESTCONTAINERS_HOST_OVERRIDE": "host.docker.internal",
    "NODE_ENV": "devcontainer",
    "ASPNETCORE_ENVIRONMENT": "Devcontainer",
    "DOTNET_USE_POLLING_FILE_WATCHER": "false"
  },
  "features": { "ghcr.io/devcontainers/features/node:2.0.0": {} },
  "postCreateCommand": "mkdir -p ~/.pi/agent && ln -sf ${containerWorkspaceFolder}/.pi/agent/models.json ~/.pi/agent/models.json && npm install -g @earendil-works/pi-coding-agent"
}